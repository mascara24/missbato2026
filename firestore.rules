rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerifiedEmail() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isVerifiedEmail() && request.auth.token.email == 'aemann1025@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---
    function isValidCandidate(data) {
      return data.name is string && data.name.size() >= 2 && data.name.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.imageUrl is string && data.imageUrl.size() <= 2000
        && data.voteCount is number && data.voteCount >= 0;
    }

    function isValidVote(data) {
      return data.userId == request.auth.uid
        && data.voterEmail == request.auth.token.email
        && isValidId(data.candidateId)
        && data.createdAt == request.time;
    }

    // --- CANDIDATE RULES ---
    match /candidates/{candidateId} {
      allow read: if true;
      
      allow create: if isAdmin() && isValidCandidate(incoming());
      
      allow delete: if isAdmin();

      allow update: if (isAdmin() && isValidCandidate(incoming())) || (
        // Action: Cast Vote (Atomic Relational Sync)
        isVerifiedEmail()
        && incoming().diff(existing()).affectedKeys().hasOnly(['voteCount', 'updatedAt'])
        && incoming().voteCount == existing().voteCount + 1
        && incoming().updatedAt == request.time
        && existsAfter(/databases/$(database)/documents/votes/$(request.auth.uid))
        && getAfter(/databases/$(database)/documents/votes/$(request.auth.uid)).data.candidateId == candidateId
      );
    }

    // --- VOTE RULES ---
    match /votes/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow create: if isVerifiedEmail()
        && userId == request.auth.uid
        && isValidVote(incoming())
        && exists(/databases/$(database)/documents/candidates/$(incoming().candidateId));

      allow delete: if isAdmin();
    }
  }
}
